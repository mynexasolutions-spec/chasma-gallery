{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "moduleResolution": "node16",
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"]
}
